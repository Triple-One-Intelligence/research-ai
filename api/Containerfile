# 1. Use the official NVIDIA base (Guarantees GPU access)
FROM docker.io/nvidia/cuda:12.4.1-devel-ubuntu22.04

# 2. Install Python
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    git \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

# 3. MAGIC STEP: Install the PRE-COMPILED llama-cpp-python wheel
# We use the extra-index-url to pull the version built for CUDA 12.4
# This takes 10 seconds, not 10 minutes.
RUN pip3 install llama-cpp-python \
    --extra-index-url https://abetlen.github.io/llama-cpp-python/whl/cu124 \
    --no-cache-dir \
    --force-reinstall

# 4. Install the rest of your dependencies
COPY api/requirements.txt .
# IMPORTANT: Use --ignore-installed or remove llama-cpp-python from requirements.txt
# so it doesn't try to overwrite our GPU version with a CPU version.
RUN pip3 install --no-cache-dir -r requirements.txt

COPY api/ /work/

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
