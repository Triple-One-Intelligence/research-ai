# --- FRONTEND ---
VITE_API_URL=/api

# --- SSH TUNNEL ---
# The dev environment tunnels to the production server for Neo4j, Ollama, etc.
# Change this to your server's IP or hostname.
# Tip: run `make dev-env-info` on the prod server to get the right values.
REMOTE_SERVER=root@YOUR_SERVER_IP

# --- API SECRETS (safe defaults for local dev only, do NOT copy to prod) ---
JWT_SECRET=local_dev_secret
SERVER_AUTH_USER=devuser
SERVER_AUTH_PASS=devpass

# --- REMOTE SERVICE URLs (Uses SSH Tunnel via localhost) ---
REMOTE_NEO4J_URL=bolt://localhost:7687
REMOTE_NEO4J_USER=neo4j
REMOTE_NEO4J_PASS=CHANGE_ME

RICGRAPH_URL=http://localhost:18080
AI_SERVICE_URL=http://localhost:11434

# --- LOGGING ---
LOGLEVEL=INFO

# --- AI MODELS ---
# Must match the prod server (dev connects to prod Neo4j via SSH tunnel).
# Run `make dev-env-info` on the prod server to see current values.
CHAT_MODEL=llama3.1:8b
EMBED_MODEL=snowflake-arctic-embed2
EMBED_DIMENSIONS=1024
OPENALEX_MAILTO=
