# --- FRONTEND ---
VITE_API_URL=/api

# Caddy Configuration (your domain name — used for HTTPS cert + routing)
CADDY_HOSTNAME=YOUR_DOMAIN

# --- NEO4J SECRETS --- (CHANGE BEFORE DEPLOYING)
NEO4J_AUTH=neo4j/CHANGE_ME

# --- API SECRETS --- (CHANGE BEFORE DEPLOYING)
JWT_SECRET=CHANGE_ME
SERVER_AUTH_USER=CHANGE_ME
SERVER_AUTH_PASS=CHANGE_ME

# --- REMOTE SERVICE URLs (Uses internal network container names) ---
REMOTE_NEO4J_URL=bolt://research-ai-neo4j:7687
REMOTE_NEO4J_USER=neo4j
REMOTE_NEO4J_PASS=CHANGE_ME

RICGRAPH_URL=http://research-ai-ricgraph:8080
AI_SERVICE_URL=http://research-ai-ai:11434

# --- LOGGING ---
LOGLEVEL=INFO

# --- EMBEDDINGS ---
# snowflake-arctic-embed2: solid multilingual, 1.2GB, fits alongside chat model.
# EMBED_NUM_GPU=0 runs embedding on CPU to keep GPU free for the chat model.
# Set EMBED_NUM_GPU=-1 during batch enrichment (make enrich-force) for GPU speed.
EMBED_MODEL=snowflake-arctic-embed2
EMBED_DIMENSIONS=1024
EMBED_NUM_GPU=0
OPENALEX_MAILTO=

# --- CHAT MODEL ---
# command-r:35b: purpose-built for RAG with inline citations [1],[2],
# zero hallucination on grounding tests, 24.7 tok/s on A10 GPU.
CHAT_MODEL=command-r:35b
CHAT_MAX_TOKENS=2048


