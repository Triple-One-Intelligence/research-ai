[Unit]
Description=Research AI Ricgraph

[Service]
Restart=always
RestartSec=5
StartLimitIntervalSec=0
StartLimitBurst=0

[Container]
ContainerName=research-ai-ricgraph
Image=ghcr.io/utrechtuniversity/ricgraph:latest
Network=research-ai-net

# Expose to localhost on the server so the SSH tunnel can reach it
# Ric explorer
PublishPort=127.0.0.1:3030:3030
PublishPort=127.0.0.1:7688:7687

EnvironmentFile=/etc/research-ai/research-ai-prod.env

Volume=ricgraph-data:/var/lib/neo4j/data

[Install]
WantedBy=multi-user.target
